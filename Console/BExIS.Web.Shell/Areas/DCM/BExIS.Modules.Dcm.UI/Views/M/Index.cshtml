@{
    ViewBag.Title = "Metadata";
    Layout = "~/Themes/Default/Layouts/_svelteLayout.cshtml";

    long id = 0;
    long version = 0;

    if (ViewData["id"] != null) { id = Convert.ToInt64(ViewData["id"]); }

    if (ViewData["version"] != null) { version = Convert.ToInt64(ViewData["version"]); }

}



<div id="metadata" dataset="@id" version="@version">
    <h1>Metadata</h1>
    @Html.Partial("_sveltePage")
</div>